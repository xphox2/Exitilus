{
  "name": "exitilus-reborn",
  "version": "0.1.0",
  "description": "Exitilus - A fantasy BBS door game, modernized",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts --local",
    "dev:enhanced": "tsx src/index.ts --local --graphics enhanced",
    "dev:telnet": "tsx src/index.ts --telnet 2323",
    "start": "node dist/index.js --local",
    "start:telnet": "node dist/index.js --telnet 2323",
    "start:door": "node dist/index.js --door",
    "admin": "tsx src/tools/admin.ts",
    "admin:list": "tsx src/tools/admin.ts list",
    "admin:bulletin": "tsx src/tools/admin.ts bulletin",
    "admin:maintenance": "tsx src/tools/admin.ts maintenance",
    "admin:reset": "tsx src/tools/admin.ts reset",
    "img2ansi": "tsx src/tools/img2ansi.ts",
    "upscale": "tsx src/tools/upscale-ansi.ts"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "sql.js": "^1.10.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
